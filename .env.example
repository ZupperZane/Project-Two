MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGODB_DB=project_two

# Firebase Admin server credentials (choose ONE option):
# 1) Set FIREBASE_SERVICE_ACCOUNT_KEY to the full JSON credentials string
# 2) OR set GOOGLE_APPLICATION_CREDENTIALS to a local JSON file path
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"<project-id>","private_key_id":"<private-key-id>","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"<client-email>","client_id":"<client-id>"}
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json

# Optional allowlists for who can self-bootstrap as admin
ADMIN_EMAILS=admin@example.com
ADMIN_UIDS=
